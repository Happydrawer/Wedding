<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wedding Invitation | Henry & Eva</title>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=Noto+Serif+TC:wght@300;500;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary-gold: #e2c08d;
            --soft-blue: #a3bcf9;
            --bg-space: #0b1121;
            --card-bg: rgba(255, 255, 255, 0.08);
            --text-main: #ffffff;
            --text-nav: #cccccc;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; scroll-behavior: smooth; }

        body {
            font-family: 'Noto Serif TC', serif;
            background-color: var(--bg-space);
            background: radial-gradient(circle at center, #1b2735 0%, #090a0f 100%);
            color: var(--text-main);
            overflow-x: hidden;
        }

        body::before {
            content: "";
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: url('https://www.transparenttextures.com/patterns/stardust.png');
            opacity: 0.4; pointer-events: none; z-index: -1;
        }

        h1, h2, h3, .en { font-family: 'Cormorant Garamond', serif; }

        /* --- Layout --- */
        .viewport-container { position: relative; width: 100%; height: 10vh; }

        .hero-container {
            position: fixed; top: 0; left: 0; width: 100%; height: 100vh;
            z-index: 50; transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1);
            overflow: hidden; pointer-events: none;
        }

        .hero-image {
            width: 100%; height: 100%;
            background: linear-gradient(rgba(11, 17, 33, 0.4), rgba(11, 17, 33, 0.7)), 
                        url('https://i.postimg.cc/FHwj9Zz1/S-191012888.jpg') center/cover no-repeat;
            display: flex; flex-direction: column; justify-content: center; align-items: center; text-align: center;
        }

        .hero-container.minimized {
            top: 20px; left: calc(100% - 140px); width: 120px; height: 120px;
            border-radius: 50%; box-shadow: 0 0 30px rgba(226, 192, 141, 0.3);
            border: 2px solid var(--primary-gold); z-index: 2000;
        }

        .hero-container.minimized .hero-content { opacity: 0; transform: scale(0.5); }
        .hero-content { transition: opacity 0.4s, transform 0.4s; padding: 0 20px; pointer-events: auto; }
        .hero h1 { font-size: clamp(2.5rem, 8vw, 4.5rem); margin-bottom: 0.5rem; letter-spacing: 3px; font-weight: 300; text-shadow: 0 0 20px rgba(226, 192, 141, 0.5); }
        .hero p { font-size: 1.2rem; letter-spacing: 4px; margin-bottom: 2rem; color: var(--primary-gold); }

        .main-content {
            position: relative; z-index: 10; margin-top: 0; padding-top: 20vh;
            opacity: 0; transform: translateY(30px); transition: opacity 1s, transform 1s;
        }
        .main-content.visible { opacity: 1; transform: translateY(0); }

        nav {
            position: fixed; top: 0; width: 100%; z-index: 1000;
            backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px);
            background: rgba(0, 0, 0, 0.3); border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            display: flex; justify-content: center; padding: 0.8rem 0; opacity: 0; transition: opacity 0.5s; pointer-events: none;
        }
        nav.active { opacity: 1; pointer-events: auto; }
        nav a { margin: 0 12px; text-decoration: none; color: var(--text-nav); font-size: 0.8rem; letter-spacing: 1px; display: flex; flex-direction: column; align-items: center; }
        nav a span.nav-en { font-family: 'Cormorant Garamond', serif; font-size: 0.65rem; opacity: 0.7; }

        .full-width-details { width: 100%; background: linear-gradient(to bottom, transparent, rgba(27, 39, 53, 0.8), transparent); padding: 40px 0; }
        .details-inner { max-width: 1000px; margin: 0 auto; padding: 0 40px; text-align: center; }
        .details-header h2 { font-size: 3rem; color: var(--primary-gold); letter-spacing: 5px; margin-bottom: 10px; }
        
        .wedding-grid { display: grid; grid-template-columns: 1fr 1px 1fr; gap: 40px; align-items: center; margin-bottom: 60px; }
        .vertical-line { background: linear-gradient(to bottom, transparent, var(--primary-gold), transparent); width: 1px; height: 100px; }
        
        .section-container { max-width: 800px; margin: 0 auto; padding: 40px 20px 100px; }
        .v-card { background: var(--card-bg); backdrop-filter: blur(20px); border-radius: 20px; padding: 50px 40px; border: 1px solid rgba(255, 255, 255, 0.1); border-top: 4px solid var(--primary-gold); text-align: center; }

        /* --- Form Elements --- */
        .form-group { margin-bottom: 25px; text-align: left; }
        label { display: block; margin-bottom: 8px; color: var(--soft-blue); font-size: 0.95rem; font-weight: 500; }
        input, select, textarea { 
            width: 100%; padding: 12px; background: rgba(255, 255, 255, 0.05); 
            border: 1px solid rgba(255, 255, 255, 0.15); color: white; border-radius: 8px;
            outline: none; transition: border-color 0.3s; font-family: inherit;
        }
        input:focus, select:focus, textarea:focus { border-color: var(--primary-gold); }
        select option { background: #1b2735; color: white; }
        
        .submit-btn { 
            width: 100%; padding: 15px; background: linear-gradient(45deg, #d4a373, #e2c08d);
            border: none; color: #1b2735; font-weight: 700; cursor: pointer; border-radius: 8px;
            margin-top: 20px; transition: all 0.3s;
        }
        .submit-btn:hover { transform: translateY(-2px); box-shadow: 0 5px 15px rgba(226, 192, 141, 0.4); }

        .countdown-wrap { display: flex; gap: 15px; justify-content: center; margin-top: 2rem; }
        .timer-card { background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(5px); padding: 10px; border-radius: 8px; min-width: 60px; border: 1px solid rgba(255, 255, 255, 0.1); }
        .timer-num { font-size: 1.5rem; color: var(--primary-gold); font-weight: 600; display: block; }
        .timer-unit { font-size: 0.6rem; color: #ccc; text-transform: uppercase; }

        footer { background: rgba(0, 0, 0, 0.8); padding: 60px 20px; text-align: center; }
        .footer-logo { font-family: 'Cormorant Garamond', serif; font-size: 2rem; color: var(--primary-gold); letter-spacing: 10px; }

        .back-to-top {
            position: fixed; bottom: 30px; right: 30px; width: 50px; height: 50px;
            background: rgba(226, 192, 141, 0.1); border: 1px solid var(--primary-gold);
            border-radius: 50%; color: var(--primary-gold); display: flex;
            justify-content: center; align-items: center; cursor: pointer; z-index: 2001;
            backdrop-filter: blur(10px); opacity: 0; visibility: hidden; transition: all 0.4s ease;
        }
        .back-to-top.visible { opacity: 1; visibility: visible; }

        @media (max-width: 768px) {
            .hero-container.minimized { left: calc(100% - 100px); width: 80px; height: 80px; top: 15px; }
            .wedding-grid { grid-template-columns: 1fr; gap: 0; }
            .vertical-line { width: 50%; height: 1px; margin: 20px auto; }
            .details-header h2 { font-size: 2.2rem; }
            .main-content { padding-top: 20vh; } 
        }
    </style>

    <script>
        let submitted = false;
        function handleFormSubmit() {
            submitted = true;
            setTimeout(() => { showSuccess(); }, 1000);
        }

        function updateTimer() {
            const target = new Date("Jan 23, 2027 12:00:00").getTime();
            const now = new Date().getTime();
            const diff = target - now;
            const dEl = document.getElementById('days'), hEl = document.getElementById('hours'), mEl = document.getElementById('mins'), sEl = document.getElementById('secs');
            if (!dEl || diff <= 0) return;
            dEl.innerText = Math.floor(diff / 86400000).toString().padStart(2, '0');
            hEl.innerText = Math.floor((diff % 86400000) / 3600000).toString().padStart(2, '0');
            mEl.innerText = Math.floor((diff % 3600000) / 60000).toString().padStart(2, '0');
            sEl.innerText = Math.floor((diff % 60000) / 1000).toString().padStart(2, '0');
        }

        window.addEventListener('scroll', () => {
            const y = window.scrollY, hero = document.getElementById('heroContainer'), main = document.getElementById('mainContent'), nav = document.querySelector('nav'), btt = document.getElementById('backToTop');
            if (y > 10) { hero.classList.add('minimized'); main.classList.add('visible'); nav.classList.add('active'); btt.classList.add('visible'); } 
            else { hero.classList.remove('minimized'); main.classList.remove('visible'); nav.classList.remove('active'); btt.classList.remove('visible'); }
        });

        function scrollToTop() { window.scrollTo({ top: 0, behavior: 'smooth' }); }
        window.onload = function() { setInterval(updateTimer, 1000); updateTimer(); };
        function showSuccess() {
            document.getElementById('rsvpForm').style.display = 'none';
            document.getElementById('successMsg').style.display = 'block';
            document.getElementById('rsvp').scrollIntoView({ behavior: 'smooth' });
        }
    </script>
</head>
<body>

    <nav>
        <a href="#about" onclick="scrollToTop()">關於我們<span class="nav-en">ABOUT</span></a>
        <a href="#details">婚禮詳情<span class="nav-en">DETAILS</span></a>
        <a href="#rsvp">出席回函<span class="nav-en">RSVP</span></a>
    </nav>

    <div id="backToTop" class="back-to-top" onclick="scrollToTop()">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m18 15-6-6-6 6"/></svg>
    </div>

    <div class="viewport-container" id="about">
        <div class="hero-container" id="heroContainer">
            <div class="hero hero-image">
                <div class="hero-content">
                    <p class="en">Our Stellar Journey Begins</p>
                    <h1>Henry & Eva</h1>
                    <p>2027 . 01 . 23</p>
                    <div class="countdown-wrap">
                        <div class="timer-card"><span class="timer-num" id="days">00</span><span class="timer-unit">Days</span></div>
                        <div class="timer-card"><span class="timer-num" id="hours">00</span><span class="timer-unit">Hrs</span></div>
                        <div class="timer-card"><span class="timer-num" id="mins">00</span><span class="timer-unit">Min</span></div>
                        <div class="timer-card"><span class="timer-num" id="secs">00</span><span class="timer-unit">Sec</span></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="main-content" id="mainContent">
        <section id="details" class="full-width-details">
            <div class="details-inner">
                <div class="details-header">
                    <h2>Wedding Details</h2>
                    <p style="letter-spacing: 8px; opacity: 0.5;">CELEBRATING OUR LOVE</p>
                </div>
                <div class="wedding-grid">
                    <div class="grid-item">
                        <h3>THE COUPLE</h3>
                        <p>新郎 | 林言融 Henry</p>
                        <p>新娘 | 藍翊方 Eva</p>
                    </div>
                    <div class="vertical-line"></div>
                    <div class="grid-item">
                        <h3>WHEN & WHERE</h3>
                        <p>2027年01月23日 (星期六)</p>
                        <p>12:00 午宴盛宴</p>
                        <p style="color: var(--primary-gold);">台中李方艾美酒店</p>
                    </div>
                </div>
            </div>
        </section>

        <div class="section-container">
            <section id="rsvp" class="v-card">
                <h2>出席回函</h2>
                <p style="margin-bottom: 30px; font-size: 0.9rem; color: #bbb;">在此璀璨時刻，誠邀您共襄盛舉。</p>
                
                <iframe name="hidden_iframe" id="hidden_iframe" style="display:none;"></iframe>
                
                <form id="rsvpForm" action="https://docs.google.com/forms/d/e/1FAIpQLSfH5o5s655FHPKHbJw6wiqc7LMVtXBcMoK5c_RL2Kzsr3Nctg/formResponse" method="post" target="hidden_iframe" onsubmit="handleFormSubmit()">
                    
                    <!-- 1. 姓名 -->
                    <div class="form-group">
                        <label>姓名 NAME</label>
                        <input type="text" name="entry.477548483" placeholder="請填寫姓名" required>
                    </div>
                    
                    <!-- 2. 聯絡電話 -->
                    <div class="form-group">
                        <label>聯絡電話 PHONE</label>
                        <input type="tel" name="entry.974963270" placeholder="請填寫聯絡電話" required>
                    </div>
                    
                    <!-- 3. 與新人關係 -->
                    <div class="form-group">
                        <label>與新人關係 RELATIONSHIP</label>
                        <select name="entry.789703691" required>
                            <option value="" disabled selected>請選擇關係</option>
                            <option value="男方親戚">男方親戚</option>
                            <option value="男方朋友">男方朋友</option>
                            <option value="男方同學">男方同學</option>
                            <option value="女方親戚">女方親戚</option>
                            <option value="女方朋友">女方朋友</option>
                            <option value="女方同學">女方同學</option>
                            <option value="雙方共同朋友">雙方共同朋友</option>
                            <option value="其他">其他</option>
                        </select>
                    </div>

                    <!-- 4. 是否出席婚禮 -->
                    <div class="form-group">
                        <label>是否出席婚禮 ATTENDANCE</label>
                        <select name="entry.905670750" required>
                            <option value="" disabled selected>請選擇出席狀況</option>
                            <option value="準時出席">準時出席</option>
                            <option value="可能出席（待確認）">可能出席（待確認）</option>
                            <option value="無法出席">無法出席</option>
                        </select>
                    </div>

                    <!-- 5. 出席人數 -->
                    <div class="form-group">
                        <label>出席人數 GUESTS</label>
                        <select name="entry.1445872456" required>
                            <option value="1位">1位</option>
                            <option value="2位">2位</option>
                            <option value="3位">3位</option>
                            <option value="4位">4位</option>
                            <option value="5位以上">5位以上</option>
                        </select>
                    </div>

                    <!-- 6. 攜伴姓名 -->
                    <div class="form-group">
                        <label>攜伴姓名 PLUS ONE NAME</label>
                        <input type="text" name="entry.723183229" placeholder="若無攜伴請填寫無">
                    </div>

                    <!-- 7. 飲食需求 -->
                    <div class="form-group">
                        <label>飲食需求 DIETARY</label>
                        <select name="entry.756254541" required>
                            <option value="葷食">葷食</option>
                            <option value="素食">素食</option>
                        </select>
                    </div>

                    <!-- 8. 是否需要兒童椅 -->
                    <div class="form-group">
                        <label>是否需要兒童椅 BABY CHAIR</label>
                        <select name="entry.1576757245" required>
                            <option value="不需要">不需要</option>
                            <option value="需要">需要</option>
                        </select>
                    </div>

                    <!-- 9. 想對新人說的話 -->
                    <div class="form-group">
                        <label>想對新人說的話 MESSAGE</label>
                        <textarea name="entry.1210359463" placeholder="留下您的祝福..."></textarea>
                    </div>

                    <button type="submit" class="submit-btn">確認送出 SUBMIT</button>
                </form>

                <div id="successMsg" style="display:none; padding:40px 20px; color:var(--primary-gold);">
                    <h3 style="margin-bottom:10px;">回覆成功！</h3>
                    <p>感謝您的回覆，我們在星空下見！</p>
                </div>
            </section>
        </div>

        <footer>
            <div class="footer-logo">H & E</div>
            <div class="footer-text">© 2027 Henry & Eva Wedding. All rights reserved.</div>
        </footer>
    </div>

</body>
</html>
